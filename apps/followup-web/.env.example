# Unified API (`services/api`). Origin only — no /api or /api/v1 suffix, no trailing slash.
# Production example: https://api.curvvtech.in
# Local: API dev server port (followup `next dev` is usually 3000; run API on 3001).
NEXT_PUBLIC_API_URL=http://127.0.0.1:3001

# Optional: preferred for `next.config.mjs` rewrites + consistency (same value as NEXT_PUBLIC_API_URL in prod).
# API_PROXY_TARGET=https://api.curvvtech.in

# Required for public waitlist/onboarding routes (must match API LANDING_API_KEY)
NEXT_PUBLIC_LANDING_API_KEY=your-landing-key
