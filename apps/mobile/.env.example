# Required: backend origin only (no trailing slash, no /v1 suffix). Rebuild after changing.
#
# Physical device + dev machine on same Wi‑Fi: use your computer’s LAN IP (not localhost).
#   EXPO_PUBLIC_API_URL=http://192.168.1.10:3000
# Production (HTTPS): use your public API host (Nginx :443), not raw EC2 :3000 — cellular often blocks :3000.
#   EXPO_PUBLIC_API_URL=https://api.example.com
#
EXPO_PUBLIC_API_URL=http://192.168.1.10:3000

# Auth: sign up / sign in against POST /auth/signup and POST /auth/login (no extra mobile env vars).
