{
  "name": "mobile",
  "version": "1.0.0",
  "main": "index.ts",
  "scripts": {
    "start": "expo start",
    "android": "expo run:android",
    "android:clean": "rm -rf android/app/.cxx android/app/build android/build",
    "android:fresh": "npm run android:clean && npx expo run:android --no-build-cache",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "postinstall": "patch-package",
    "build:android:apk": "cd android && ./gradlew assembleRelease",
    "build:android:debug": "cd android && ./gradlew assembleDebug"
  },
  "dependencies": {
    "@expo-google-fonts/montserrat": "^0.4.2",
    "@expo/vector-icons": "^15.1.1",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-native-community/datetimepicker": "8.6.0",
    "@react-navigation/bottom-tabs": "^7.15.8",
    "@react-navigation/native": "^7.2.1",
    "@react-navigation/native-stack": "^7.14.9",
    "@tanstack/react-query": "^5.95.2",
    "axios": "^1.14.0",
    "expo": "~55.0.8",
    "expo-blur": "~55.0.13",
    "expo-clipboard": "~55.0.12",
    "expo-constants": "~55.0.9",
    "expo-contacts": "~55.0.12",
    "expo-font": "^55.0.4",
    "expo-image-picker": "~55.0.14",
    "expo-linear-gradient": "~55.0.9",
    "expo-secure-store": "~55.0.9",
    "expo-status-bar": "~55.0.4",
    "react": "19.2.0",
    "react-native": "0.83.2",
    "react-native-gesture-handler": "~2.30.0",
    "react-native-keyboard-aware-scroll-view": "^0.9.5",
    "react-native-receive-sharing-intent": "^2.0.0",
    "react-native-safe-area-context": "~5.6.2",
    "react-native-screens": "~4.23.0"
  },
  "devDependencies": {
    "@types/react": "~19.2.2",
    "patch-package": "^8.0.1",
    "typescript": "~5.9.2"
  },
  "private": true
}
