# Copy to .deploy.env (gitignored) — deploy-only; no secrets required here.
# Used by scripts/deploy-ec2.sh when present.

export AWS_REGION=ap-south-1
export EC2_INSTANCE_ID=i-xxxxxxxxxxxxxxxxx
export EC2_SSH_KEY="/absolute/or/repo/path/to/FOLLOWUP.pem"

# Ubuntu AMI: often needed
# export EC2_SSH_USER=ubuntu

