PORT=3000
HOST=0.0.0.0
# Local Docker Postgres, or the same Neon URL as the marketing site (run `npm run migrate` once).
DATABASE_URL=postgresql://followup:followup@localhost:5432/followup
LOG_LEVEL=info

# OpenAI (lead parsing + /v1/ai/chat)
OPENAI_API_KEY=

# JWT auth (required when SKIP_AUTH=false). Generate strong random strings, e.g. openssl rand -base64 64
JWT_SECRET=
# Refresh tokens are opaque strings stored hashed in DB (not JWT). No separate refresh secret.
# Access / refresh lifetimes (seconds). Defaults: 900 (15m) and 2592000 (30d).
# JWT_ACCESS_EXPIRES_SEC=900
# JWT_REFRESH_EXPIRES_SEC=2592000

# Legacy (unused by mobile; optional for old tooling)
# COGNITO_REGION=
# COGNITO_USER_POOL_ID=
# COGNITO_CLIENT_ID=

# Local dev: bypass JWT (never in production)
SKIP_AUTH=true
DEV_AUTH_SUB=dev-local-auth-sub
DEV_AUTH_EMAIL=dev@local.followup

# First N signups get access_allowed=true (waitlist after that)
ACCESS_CAP=1000

# Landing site proxy (optional): same secret in Next.js FOLLOWUP_LANDING_API_KEY
LANDING_API_KEY=

# S3 presigned uploads (optional)
# AWS_REGION=us-east-1
# S3_BUCKET=
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=

# CORS (comma-separated); leave empty to reflect request origin in dev
# CORS_ORIGINS=https://app.example.com

# Redis (optional; enables distributed rate limiting across API instances)
# REDIS_URL=redis://localhost:6379

# WhatsApp Cloud API — webhooks (GET verify + POST) and outbound sends
# WHATSAPP_WEBHOOK_VERIFY_TOKEN=your-random-string
# WHATSAPP_APP_SECRET=Meta App secret (X-Hub-Signature-256 on POST)
# WHATSAPP_GRAPH_ACCESS_TOKEN=System user / permanent token for Graph API sends
# Production: enforce signature verification (default true). Set false only for emergency debugging.
# REQUIRE_WHATSAPP_SIGNATURE=true
# Link numbers to tenants via whatsapp_accounts (or PATCH /v1/me/whatsapp for the first tenant).

# Demo booking — calendar invites when admin clicks "Confirm" (Google Workspace: use an App Password for SMTP)
# DEMO_SMTP_HOST=smtp.gmail.com
# DEMO_SMTP_PORT=587
# DEMO_SMTP_SECURE=false
# DEMO_SMTP_USER=advaitsingh@curvvtech.in
# DEMO_SMTP_PASS=your-app-password
# DEMO_CALENDAR_FROM_EMAIL=advaitsingh@curvvtech.in
# DEMO_CALENDAR_ORGANIZER_NAME=CurvvTech
# DEMO_MEETING_TITLE=CurvvTech · FollowUp product demo
# DEMO_MEETING_LOCATION=Online — meeting link will be shared separately

# Razorpay (FollowUp SaaS billing — create Plans in Razorpay Dashboard, set webhook to POST /api/v1/billing/webhooks/razorpay)
# RAZORPAY_KEY_ID=
# RAZORPAY_KEY_SECRET=
# RAZORPAY_WEBHOOK_SECRET=
# RAZORPAY_PLAN_PRO_MONTHLY=
# RAZORPAY_PLAN_PRO_ANNUAL=
# RAZORPAY_PLAN_PRO_PLUS_MONTHLY=
# RAZORPAY_PLAN_PRO_PLUS_ANNUAL=
